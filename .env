# Copy to .env (or set in your shell) before `docker compose up`.
# All values are optional — defaults work for a standard local setup.

# Ollama model to use. qwen3.5:9b is the recommended default for M1 16GB —
# a generation newer than qwen2.5 at the same ~6.6GB (Q4_K_M) footprint, used
# for both content generation and the design-brain pass (services/design_brain.py).
OLLAMA_MODEL=qwen3.6:35b-a3b #"qwen3.6:35b-q4_K_M"

# Request timeout for LLM calls (seconds). Large prompts on 14b may need 240+.
OLLAMA_TIMEOUT_SECONDS=300

# webtree CMS API base URL (used by Phase 4 push). Defaults to the host machine.
CMS_API_BASE_URL=http://host.docker.internal


PEXELS_API_KEY=ELe9prz0BNDY83mvXFPtyqVfgt514ARXEvKBjC9DgmMzOB6YucZqD7AE

LLM_BACKEND=ollama
OLLAMA_KEEP_ALIVE=30m