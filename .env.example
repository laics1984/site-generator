# Webtree Site Generator — environment configuration
#
# Copy to .env and uncomment what you want to change. Every setting in
# backend/app/config.py can be set here (env name = upper-cased field name).
# Values shown are the defaults. docker-compose passes this whole file to the
# backend container (env_file), so no compose edits are needed for new knobs.
# NB: in Docker, OLLAMA_BASE_URL / MLX_BASE_URL / CMS_API_BASE_URL are rewritten
# to host.docker.internal by docker-compose.yml — see its `environment:` block.

# --- LLM backend selection -------------------------------------------------
# `ollama` (default; Windows, or a Mac running `ollama serve`) or `mlx`
# (Apple-Silicon host running mlx_lm.server natively — see dev.sh).
#LLM_BACKEND=ollama

# --- Ollama ------------------------------------------------------------------
# OLLAMA_BASE_URL may point at a REMOTE Ollama (e.g. the AI server) — compose
# passes a set value through and only defaults to host.docker.internal when
# unset. See "Single-GPU AI-server setup" below for the recommended remote
# configuration.
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=qwen3.5:9b
#OLLAMA_TIMEOUT_SECONDS=180
# How long Ollama keeps the model resident after a request (avoids cold reloads
# between the picker's brand-detect and generate calls).
#OLLAMA_KEEP_ALIVE=30m

# --- Single-GPU AI-server setup (both roles on one remote Ollama) -------------
# Runs the content model AND the reasoning model on the AI server
# (RTX 5060 Ti 16GB), swap-on-demand so each model gets the whole GPU:
#   on the AI server:  OLLAMA_MAX_LOADED_MODELS=1  (Ollama service env — evicts
#   one model to load the other; ~2 swaps per generation, seconds each from
#   page cache), and `ollama pull` both model tags.
# Recommended pairing for 16GB VRAM (verify exact tags with `ollama list`):
#   content   — Qwen3-30B-A3B Q4 (MoE: 30B-class copy, offload-tolerant)
#   reasoning — GLM-Z1-9B Q8 (fully resident, thinking on)
# Then in this file:
#OLLAMA_BASE_URL=http://<ai-server>:11434
#OLLAMA_MODEL=qwen3:30b-a3b
#REASONING_BACKEND=ollama
#REASONING_BASE_URL=http://<ai-server>:11434
#REASONING_MODEL=glm-z1:9b-q8_0
# A 30B-class content model degrades less on big batches — consider raising
# MAX_PAGES_PER_BATCH / MAX_SECTIONS_PER_BATCH to cut round-trips.
# ALTERNATIVE (fastest content role, no model swaps): serve Qwen3-30B resident
# on the AI server via llama.cpp llama-server with expert-only CPU offload —
# see ai-server/README.md. Content then uses LLM_BACKEND=mlx + MLX_BASE_URL
# below; the reasoning role keeps the REASONING_* settings (Ollama on the same
# box, port 11434).

# --- "mlx" = any OpenAI-compatible /v1 server: mlx_lm.server on the Mac host
# (HuggingFace repo ids) or llama-server on the remote AI box (--alias id,
# e.g. MLX_BASE_URL=http://<ai-server>:8080 + MLX_MODEL=qwen3-30b-a3b —
# see ai-server/README.md).
#MLX_BASE_URL=http://localhost:8080
#MLX_MODEL=mlx-community/Qwen3-4B-4bit
#MLX_TIMEOUT_SECONDS=600
# Output budget per call (OpenAI servers default too low for multi-section JSON).
#MLX_MAX_TOKENS=8192
# Opt-in MLX vision server (mlx_vlm.server). Unset ⇒ vision pass falls back/skips.
#MLX_VISION_BASE_URL=
#MLX_VISION_MODEL=

# --- Reasoning role: bigger remote model (e.g. GLM on the AI server) ----------
# Routes the judgment-heavy calls — brand detection, the design-brain passes
# (design recipe + design language), and the image tie-break judge — to a
# second model while the local default model keeps content generation.
# Unset REASONING_MODEL ⇒ role disabled (those calls use the default model).
# REASONING_BACKEND picks the wire protocol: `mlx` = any OpenAI-compatible
# server (vLLM, sglang, llama.cpp, LM Studio, mlx_lm.server), `ollama` =
# Ollama API. Unset ⇒ inherits LLM_BACKEND. NB: in Docker, a same-host server
# needs host.docker.internal, not localhost (compose does NOT rewrite this URL).
# Example A — Ollama on the AI server (RTX 5060 Ti 16GB):
#REASONING_BACKEND=ollama
#REASONING_BASE_URL=http://<ai-server>:11434
#REASONING_MODEL=glm-z1:9b
# Example B — OpenAI-compatible server (vLLM / llama.cpp / LM Studio):
#REASONING_BACKEND=mlx
#REASONING_BASE_URL=http://<ai-server>:8000
#REASONING_MODEL=THUDM/GLM-Z1-9B-0414
#REASONING_API_KEY=
#REASONING_TIMEOUT_SECONDS=600
# OpenAI-path output budget; thinking tokens count against it.
#REASONING_MAX_TOKENS=16384
# Ollama-path context for calls that pass no num_ctx (brand detection). The
# design/judge calls use DESIGN_NUM_CTX/JUDGE_NUM_CTX — raise those instead.
#REASONING_NUM_CTX=
# Thinking ON by default for this role; set false if a model/server combo
# breaks JSON mode with its reasoning channel enabled.
#REASONING_THINK=true

# --- LLM tuning (model-variant knobs; retune when swapping models) ------------
# Client defaults, used when a call site doesn't set its own value.
#LLM_DEFAULT_TEMPERATURE=0.4
#LLM_DEFAULT_NUM_CTX=4096
# Hybrid-thinking toggle (Qwen3-style models). Off ⇒ clean JSON output.
#LLM_THINK=false

# Per-call-class values.
#PLAN_TEMPERATURE=0.3           # brand detection + legacy free-form planner
#SCAFFOLD_TEMPERATURE=0.25      # scaffolded content generation
#SCAFFOLD_NUM_CTX=8192          # context window for scaffolded planning calls
#DESIGN_TEMPERATURE=0.7         # design-brain pass (bolder layout picks)
#DESIGN_NUM_CTX=8192
#JUDGE_TEMPERATURE=0.0          # deterministic judges (image tie-break, vision)
#JUDGE_NUM_CTX=2048

# Prompt sizing / batching caps (keyed to the model's usable context window).
#BRAND_DETECTION_MAX_CHARS=4000
#MULTIPASS_MAX_CHARS_PER_CALL=6000
#MAX_SECTIONS_PER_BATCH=6
#MAX_PAGES_PER_BATCH=4
#LEGACY_PROMPT_MAX_CHARS=24000

# --- Design brain / layout features -------------------------------------------
#DESIGN_BRAIN_ENABLED=true
# LLM picks the curated palette + font pairing before theme construction.
# Off ⇒ deterministic theming (industry/hue/seed pickers), exactly as before.
#DESIGN_LANGUAGE_ENABLED=true
#HERO_FULLBLEED_ALL_PAGES=true
#HERO_MIN_BACKGROUND_DIM=1200
#HEADER_OVERLAY_ENABLED=true
#HEADER_SCROLL_REVEAL_OFFSET=80
#HEADER_SHRINK_ENABLED=true
#HEADER_SHRINK_AMOUNT=80
#LUMINANCE_RHYTHM_ENABLED=true

# --- Vision pass over scraped images (opt-in) ----------------------------------
# Set to a multimodal Ollama model (e.g. qwen2.5vl:7b) to enable. Unset ⇒ skipped.
#OLLAMA_VISION_MODEL=
#VISION_MAX_IMAGES=12
#VISION_IMAGE_MAX_BYTES=4000000
#VISION_FETCH_TIMEOUT_SECONDS=8

# --- Pexels stock photos ---------------------------------------------------------
# Free key (instant, no credit card): https://www.pexels.com/api/
# REQUIRED for real photos; if empty, the generator falls back to Picsum.
#PEXELS_API_KEY=
#PEXELS_BASE_URL=https://api.pexels.com/v1
#PEXELS_TIMEOUT_SECONDS=10
#PEXELS_CACHE_SIZE=256

# --- Content migration (blog/events crawl → CMS entries) -----------------------
#CONTENT_MIGRATION_ENABLED=true
#CONTENT_MIGRATION_MAX_ENTRIES=12

# --- Integration -----------------------------------------------------------------
#CMS_API_BASE_URL=http://localhost:8000
