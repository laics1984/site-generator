# Copy to .env (or set in your shell) before `docker compose up`.
# All values are optional — defaults work for a standard local setup.

# Ollama model to use. qwen2.5:7b-instruct is the recommended default for M1 16GB.
# For higher quality copy at the cost of speed, use qwen2.5:14b-instruct.
OLLAMA_MODEL=qwen2.5:7b-instruct

# Request timeout for LLM calls (seconds). Large prompts on 14b may need 240+.
OLLAMA_TIMEOUT_SECONDS=180

# Pexels free API key — REQUIRED for real photos in generated sites.
# Sign up (instant, no credit card): https://www.pexels.com/api/
# If left empty, the generator falls back to Picsum placeholder photos.
PEXELS_API_KEY=

# webtree CMS API base URL (used by Phase 4 push). Defaults to the host machine.
CMS_API_BASE_URL=http://host.docker.internal:8000
