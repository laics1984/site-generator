# Webtree Site Generator — environment configuration
#
# Copy to .env and uncomment what you want to change. Every setting in
# backend/app/config.py can be set here (env name = upper-cased field name).
# Values shown are the defaults. docker-compose passes this whole file to the
# backend container (env_file), so no compose edits are needed for new knobs.
# NB: in Docker, OLLAMA_BASE_URL / MLX_BASE_URL / CMS_API_BASE_URL are rewritten
# to host.docker.internal by docker-compose.yml — see its `environment:` block.

# --- LLM backend selection -------------------------------------------------
# `ollama` (default; Windows, or a Mac running `ollama serve`) or `mlx`
# (Apple-Silicon host running mlx_lm.server natively — see dev.sh).
#LLM_BACKEND=ollama

# --- Ollama ------------------------------------------------------------------
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=qwen3.5:9b
#OLLAMA_TIMEOUT_SECONDS=180
# How long Ollama keeps the model resident after a request (avoids cold reloads
# between the picker's brand-detect and generate calls).
#OLLAMA_KEEP_ALIVE=30m

# --- MLX (OpenAI-compatible mlx_lm.server; HuggingFace repo ids, not Ollama tags)
#MLX_BASE_URL=http://localhost:8080
#MLX_MODEL=mlx-community/Qwen3-4B-4bit
#MLX_TIMEOUT_SECONDS=600
# Output budget per call (OpenAI servers default too low for multi-section JSON).
#MLX_MAX_TOKENS=8192
# Opt-in MLX vision server (mlx_vlm.server). Unset ⇒ vision pass falls back/skips.
#MLX_VISION_BASE_URL=
#MLX_VISION_MODEL=

# --- LLM tuning (model-variant knobs; retune when swapping models) ------------
# Client defaults, used when a call site doesn't set its own value.
#LLM_DEFAULT_TEMPERATURE=0.4
#LLM_DEFAULT_NUM_CTX=4096
# Hybrid-thinking toggle (Qwen3-style models). Off ⇒ clean JSON output.
#LLM_THINK=false

# Per-call-class values.
#PLAN_TEMPERATURE=0.3           # brand detection + legacy free-form planner
#SCAFFOLD_TEMPERATURE=0.25      # scaffolded content generation
#SCAFFOLD_NUM_CTX=8192          # context window for scaffolded planning calls
#DESIGN_TEMPERATURE=0.7         # design-brain pass (bolder layout picks)
#DESIGN_NUM_CTX=8192
#JUDGE_TEMPERATURE=0.0          # deterministic judges (image tie-break, vision)
#JUDGE_NUM_CTX=2048

# Prompt sizing / batching caps (keyed to the model's usable context window).
#BRAND_DETECTION_MAX_CHARS=4000
#MULTIPASS_MAX_CHARS_PER_CALL=6000
#MAX_SECTIONS_PER_BATCH=6
#MAX_PAGES_PER_BATCH=4
#LEGACY_PROMPT_MAX_CHARS=24000

# --- Design brain / layout features -------------------------------------------
#DESIGN_BRAIN_ENABLED=true
#HERO_FULLBLEED_ALL_PAGES=true
#HERO_MIN_BACKGROUND_DIM=1200
#HEADER_OVERLAY_ENABLED=true
#HEADER_SCROLL_REVEAL_OFFSET=80
#HEADER_SHRINK_ENABLED=true
#HEADER_SHRINK_AMOUNT=80
#LUMINANCE_RHYTHM_ENABLED=true

# --- Vision pass over scraped images (opt-in) ----------------------------------
# Set to a multimodal Ollama model (e.g. qwen2.5vl:7b) to enable. Unset ⇒ skipped.
#OLLAMA_VISION_MODEL=
#VISION_MAX_IMAGES=12
#VISION_IMAGE_MAX_BYTES=4000000
#VISION_FETCH_TIMEOUT_SECONDS=8

# --- Pexels stock photos ---------------------------------------------------------
# Free key (instant, no credit card): https://www.pexels.com/api/
# REQUIRED for real photos; if empty, the generator falls back to Picsum.
#PEXELS_API_KEY=
#PEXELS_BASE_URL=https://api.pexels.com/v1
#PEXELS_TIMEOUT_SECONDS=10
#PEXELS_CACHE_SIZE=256

# --- Content migration (blog/events crawl → CMS entries) -----------------------
#CONTENT_MIGRATION_ENABLED=true
#CONTENT_MIGRATION_MAX_ENTRIES=12

# --- Integration -----------------------------------------------------------------
#CMS_API_BASE_URL=http://localhost:8000
